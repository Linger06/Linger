<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net10.0;net9.0;net8.0;netstandard2.0;net472;</TargetFrameworks>
    <Version>1.4.2</Version>
    <Description>
      A lightweight implementation of Linger.HttpClient.Contracts using standard .NET HttpClient.
      Provides robust HTTP request handling with automatic retries, timeout management, and typed response parsing.
      Seamlessly integrates with .NET's HttpClientFactory for optimal connection management.
    </Description>
</PropertyGroup>

  <ItemGroup>
</ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.8" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)'=='net472'">
    <Reference Include="System.Net.Http" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Linger.HttpClient.Contracts\Linger.HttpClient.Contracts.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Update="Microsoft.SourceLink.GitHub" Version="10.0.300" />
  </ItemGroup>

</Project>
